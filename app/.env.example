APP_ENV=development
# Android emulator: use 10.0.2.2
BASE_URL=http://10.0.2.2:5000/api
# Physical phone on same Wi-Fi: set your PC LAN IP (run ipconfig on Windows)
LAN_BASE_URL=http://192.168.1.5:5000/api
SOCKET_URL=http://10.0.2.2:5000
GOOGLE_MAPS_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
# Run `flutterfire configure` and add google-services.json / GoogleService-Info.plist for FCM.
# Backend push uses FCM_SERVICE_ACCOUNT_JSON (see backend/.env.example).
